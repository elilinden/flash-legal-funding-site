---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">
{%- set site = "https://flashlegalfunding.com" %}
{%- set defaultImage = site + "/assets/og-image.png" %}
{% for page in collections.all %}
  {%- if page.url
        and page.outputPath
        and page.outputPath.endsWith(".html")
        and page.url != "/404/"
        and page.url != "/sitemap.xml"
        and page.url != "/sitemap/"
  %}
  {%- set pageImage = defaultImage %}
  {%- if page.data.image %}{% set pageImage = site + page.data.image %}{% endif %}
  {%- set imageTitle = page.data.title or "Flash Legal Funding" %}
  {%- set imageCaption = page.data.description or "Non-recourse pre-settlement funding for personal injury cases" %}
  <url>
    <loc>{{ site }}{{ page.url }}</loc>
    <lastmod>{% if page.data.dateModified %}{{ page.data.dateModified.toISOString() }}{% else %}{{ page.inputPath | mtime or page.date.toISOString() }}{% endif %}</lastmod>
    {%- if page.url == "/" %}
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
    {%- elif page.url == "/apply/" or page.url == "/contact/" or page.url == "/faq/" or page.url == "/for-attorneys/" %}
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
    {%- elif page.url.endsWith("-funding/") and page.url != "/" and not page.url.startsWith("/posts/") %}
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
    {%- elif page.url == "/blog/" %}
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
    {%- elif page.url.startsWith("/posts/") %}
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
    {%- else %}
    <changefreq>yearly</changefreq>
    <priority>0.5</priority>
    {%- endif %}
    <image:image>
      <image:loc>{{ pageImage }}</image:loc>
      <image:title>{{ imageTitle | escape }}</image:title>
      <image:caption>{{ imageCaption | escape }}</image:caption>
    </image:image>
  </url>
  {%- endif %}
{% endfor %}
</urlset>
